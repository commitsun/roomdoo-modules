<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_users_form_feature_flags" model="ir.ui.view">
        <field name="name">res.users.form.feature.flags</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page
          string="Feature Flags"
          name="feature_flags"
          groups="base.group_system"
        >
                    <field
            name="feature_flag_ids"
            widget="many2many_tags"
            domain="[('is_active_instance', '=', False)]"
            help="Feature flags active for this user. Flags active for the entire instance are applied automatically."
          />
                </page>
            </xpath>
        </field>
    </record>

</odoo>
