<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="pms_room_view_form" model="ir.ui.view">
        <field name="name">pms.room.form.smartlock</field>
        <field name="model">pms.room</field>
        <field name="inherit_id" ref="pms.pms_room_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page
          name="smartlock"
          string="Smart Lock"
          groups="pms_smartlock_base.group_smartlock_admin"
        >
                    <group>
                        <field name="lock_vendor_id" />
                        <field name="lock_device_id" />
                        <field
              name="shared_lock_ids"
              widget="many2many_tags"
              options="{'no_create': True}"
            />
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
