<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="lock_code_view_tree" model="ir.ui.view">
        <field name="name">lock.code.tree</field>
        <field name="model">lock.code</field>
        <field name="arch" type="xml">
            <tree
        decoration-success="state == 'active'"
        decoration-info="state == 'scheduled'"
        decoration-warning="state == 'syncing'"
        decoration-muted="state in ('cancelled','expired')"
        decoration-danger="state == 'failed'"
      >
                <field name="room_id" />
                <field name="reservation_id" />
                <field
          name="vendor_id"
          groups="pms_smartlock_base.group_smartlock_admin"
        />
                <field name="date_from" />
                <field name="date_to" />
                <field name="state" />
                <field name="vendor_code_id" optional="hide" />
                <field name="active" invisible="1" />
            </tree>
        </field>
    </record>

    <record id="lock_code_view_form" model="ir.ui.view">
        <field name="name">lock.code.form</field>
        <field name="model">lock.code</field>
        <field name="arch" type="xml">
            <form string="Lock Code">
                <header>
                    <button
            name="action_reveal_pin"
            type="object"
            string="Reveal PIN"
            class="btn-primary"
            help="Reveal the PIN. Each click is recorded in the audit log."
          />
                    <field
            name="state"
            widget="statusbar"
            statusbar_visible="pending,syncing,scheduled,active,cancelled"
          />
                </header>
                <sheet>
                    <widget
            name="web_ribbon"
            title="Archived"
            bg_color="bg-danger"
            attrs="{'invisible': [('active', '=', True)]}"
          />
                    <group>
                        <group>
                            <field
                name="vendor_id"
                groups="pms_smartlock_base.group_smartlock_admin"
              />
                            <field name="room_id" />
                            <field name="reservation_id" />
                        </group>
                        <group>
                            <field name="date_from" />
                            <field name="date_to" />
                            <field name="vendor_code_id" readonly="1" />
                            <field name="active" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Sync Jobs" name="sync_jobs">
                            <field name="queue_job_ids" readonly="1">
                                <tree
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'failed'"
                  decoration-warning="state in ('enqueued','started')"
                  decoration-muted="state in ('cancelled','wait_dependencies')"
                >
                                    <field name="date_created" />
                                    <field name="method_name" />
                                    <field name="state" />
                                    <field name="retry" />
                                    <field name="max_retries" optional="hide" />
                                    <field name="exc_info" optional="hide" />
                                </tree>
                            </field>
                        </page>
                        <page
              string="Access Log"
              name="access_log"
              groups="pms_smartlock_base.group_smartlock_admin"
            >
                            <field name="access_log_ids" readonly="1">
                                <tree>
                                    <field name="accessed_at" />
                                    <field name="user_id" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lock_code_view_search" model="ir.ui.view">
        <field name="name">lock.code.search</field>
        <field name="model">lock.code</field>
        <field name="arch" type="xml">
            <search>
                <field name="vendor_code_id" />
                <field name="room_id" />
                <field name="reservation_id" />
                <field
          name="vendor_id"
          groups="pms_smartlock_base.group_smartlock_admin"
        />
                <filter
          name="state_active"
          string="Active"
          domain="[('state', '=', 'active')]"
        />
                <filter
          name="state_scheduled"
          string="Scheduled"
          domain="[('state', '=', 'scheduled')]"
        />
                <filter
          name="state_syncing"
          string="Syncing"
          domain="[('state', '=', 'syncing')]"
        />
                <filter
          name="state_pending"
          string="Pending"
          domain="[('state', '=', 'pending')]"
        />
                <filter
          name="state_failed"
          string="Failed"
          domain="[('state', '=', 'failed')]"
        />
                <separator />
                <filter
          name="archived"
          string="Archived"
          domain="[('active', '=', False)]"
        />
                <group expand="0" string="Group By">
                    <filter
            name="group_state"
            string="State"
            context="{'group_by': 'state'}"
          />
                    <filter
            name="group_vendor"
            string="Vendor"
            context="{'group_by': 'vendor_id'}"
            groups="pms_smartlock_base.group_smartlock_admin"
          />
                    <filter
            name="group_room"
            string="Room"
            context="{'group_by': 'room_id'}"
          />
                </group>
            </search>
        </field>
    </record>

    <record id="lock_code_action" model="ir.actions.act_window">
        <field name="name">Lock Codes</field>
        <field name="res_model">lock.code</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="lock_code_view_search" />
    </record>

</odoo>
