<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="lock_code_view_tree" model="ir.ui.view">
        <field name="name">lock.code.tree</field>
        <field name="model">lock.code</field>
        <field name="arch" type="xml">
            <tree
        decoration-success="state == 'active'"
        decoration-muted="state in ('cancelled','expired')"
        decoration-danger="state == 'failed'"
      >
                <field name="pin" />
                <field name="room_id" />
                <field name="reservation_id" />
                <field name="vendor_id" />
                <field name="date_from" />
                <field name="date_to" />
                <field name="state" />
                <field name="vendor_code_id" optional="hide" />
                <field name="active" invisible="1" />
            </tree>
        </field>
    </record>

    <record id="lock_code_view_form" model="ir.ui.view">
        <field name="name">lock.code.form</field>
        <field name="model">lock.code</field>
        <field name="arch" type="xml">
            <form string="Lock Code">
                <header>
                    <field
            name="state"
            widget="statusbar"
            statusbar_visible="pending,active,cancelled"
          />
                </header>
                <sheet>
                    <widget
            name="web_ribbon"
            title="Archived"
            bg_color="bg-danger"
            attrs="{'invisible': [('active', '=', True)]}"
          />
                    <div class="oe_title">
                        <label for="pin" string="PIN" />
                        <h1>
                            <field name="pin" placeholder="auto-generated" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="vendor_id" />
                            <field name="room_id" />
                            <field name="reservation_id" />
                        </group>
                        <group>
                            <field name="date_from" />
                            <field name="date_to" />
                            <field name="vendor_code_id" readonly="1" />
                            <field name="active" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lock_code_view_search" model="ir.ui.view">
        <field name="name">lock.code.search</field>
        <field name="model">lock.code</field>
        <field name="arch" type="xml">
            <search>
                <field name="pin" />
                <field name="vendor_code_id" />
                <field name="room_id" />
                <field name="reservation_id" />
                <field name="vendor_id" />
                <filter
          name="state_active"
          string="Active"
          domain="[('state', '=', 'active')]"
        />
                <filter
          name="state_pending"
          string="Pending"
          domain="[('state', '=', 'pending')]"
        />
                <filter
          name="state_failed"
          string="Failed"
          domain="[('state', '=', 'failed')]"
        />
                <separator />
                <filter
          name="archived"
          string="Archived"
          domain="[('active', '=', False)]"
        />
                <group expand="0" string="Group By">
                    <filter
            name="group_state"
            string="State"
            context="{'group_by': 'state'}"
          />
                    <filter
            name="group_vendor"
            string="Vendor"
            context="{'group_by': 'vendor_id'}"
          />
                    <filter
            name="group_room"
            string="Room"
            context="{'group_by': 'room_id'}"
          />
                </group>
            </search>
        </field>
    </record>

    <record id="lock_code_action" model="ir.actions.act_window">
        <field name="name">Lock Codes</field>
        <field name="res_model">lock.code</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="lock_code_view_search" />
    </record>

</odoo>
