<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="lock_vendor_view_tree" model="ir.ui.view">
        <field name="name">lock.vendor.tree</field>
        <field name="model">lock.vendor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="vendor_type" />
                <field name="pms_property_id" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="active" invisible="1" />
            </tree>
        </field>
    </record>

    <record id="lock_vendor_view_form" model="ir.ui.view">
        <field name="name">lock.vendor.form</field>
        <field name="model">lock.vendor</field>
        <field name="arch" type="xml">
            <form string="Lock Vendor">
                <sheet>
                    <widget
            name="web_ribbon"
            title="Archived"
            bg_color="bg-danger"
            attrs="{'invisible': [('active', '=', True)]}"
          />
                    <div class="oe_title">
                        <label for="name" string="Name" />
                        <h1>
                            <field name="name" placeholder="e.g. Main hotel locks" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="vendor_type" />
                            <field name="pms_property_id" />
                            <field
                name="company_id"
                groups="base.group_multi_company"
              />
                            <field name="pin_confirm_key" />
                        </group>
                        <group>
                            <field name="sequence" />
                            <field name="active" />
                        </group>
                    </group>
                    <notebook>
                        <page name="notes" string="Notes">
                            <field name="note" placeholder="Internal notes..." />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lock_vendor_view_search" model="ir.ui.view">
        <field name="name">lock.vendor.search</field>
        <field name="model">lock.vendor</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="vendor_type" />
                <field name="pms_property_id" />
                <filter
          name="archived"
          string="Archived"
          domain="[('active', '=', False)]"
        />
                <group expand="0" string="Group By">
                    <filter
            name="group_vendor_type"
            string="Type"
            context="{'group_by': 'vendor_type'}"
          />
                    <filter
            name="group_property"
            string="Property"
            context="{'group_by': 'pms_property_id'}"
          />
                </group>
            </search>
        </field>
    </record>

    <record id="lock_vendor_action" model="ir.actions.act_window">
        <field name="name">Lock Vendors</field>
        <field name="res_model">lock.vendor</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="lock_vendor_view_search" />
    </record>

</odoo>
