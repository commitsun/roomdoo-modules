<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="pms_reservation_view_form" model="ir.ui.view">
        <field name="name">pms.reservation.form.smartlock</field>
        <field name="model">pms.reservation</field>
        <field name="inherit_id" ref="pms.pms_reservation_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="smartlock" string="Smart Lock Codes">
                    <button
            name="action_generate_lock_codes"
            type="object"
            string="Generate Codes Now"
            class="btn-secondary"
            attrs="{'invisible': [('state', 'in', ('draft', 'cancel'))]}"
            help="Force generation of lock codes for this reservation, ignoring the 24h horizon. No-op if codes already exist."
          />
                    <field name="lock_code_ids">
                        <tree
              decoration-success="state == 'active'"
              decoration-info="state == 'scheduled'"
              decoration-muted="state in ('cancelled','expired')"
              decoration-danger="state == 'failed'"
            >
                            <field name="pin" />
                            <field name="room_id" />
                            <field name="vendor_id" />
                            <field name="date_from" />
                            <field name="date_to" />
                            <field name="state" />
                            <field name="vendor_code_id" optional="hide" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
