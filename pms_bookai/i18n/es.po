#. module: pms_bookai
#: model:pms.notification.template,body:pms_bookai.pms_notification_template_folio_request_eta_whatsapp
msgid ""
"Hello {{ buyer_name }}, to prepare your arrival at {{ hotel_name }}, could "
"you please tell us your approximate arrival time?\n"
"You can reply directly to this message."
msgstr ""
"Hola {{ buyer_name }}, para preparar tu llegada a {{ hotel_name }}, ¿podrías "
"indicarnos tu hora aproximada de llegada?\n"
"Puedes responder directamente a este mensaje."

#. module: pms_bookai
#: model:pms.notification.template,body:pms_bookai.pms_notification_template_folio_reactivate_chat_critical_whatsapp
msgid ""
"Hello {{ buyer_name }}, we have an important pending action for your "
"reservation {{ reservation_locator }} at {{ hotel_name }}.\n"
"To continue, we need your confirmation.\n"
"Reply \"yes\" now and we will continue."
msgstr ""
"Hola {{ buyer_name }}, tenemos pendiente una gestión importante de tu "
"reserva {{ reservation_locator }} en {{ hotel_name }}.\n"
"Para poder continuar necesitamos tu confirmación.\n"
"Respóndenos \"si\" ahora y seguimos."

#. module: pms_bookai
#: model:pms.notification.template,body:pms_bookai.pms_notification_template_folio_booking_confirmation_whatsapp
msgid ""
"Hello {{ buyer_name }}, your reservation at {{ hotel_name }} has been "
"confirmed.\n"
"Check-in: {{ checkin_date }}\n"
"Check-out: {{ checkout_date }}\n"
"Locator: {{ reservation_locator }}\n"
"You can manage your reservation (payment, pre-check-in, details, etc.) "
"here:\n"
"{{ reservation_details_url }}"
msgstr ""
"Hola {{ buyer_name }}, tu reserva en {{ hotel_name }} ha sido confirmada.\n"
"Entrada: {{ checkin_date }}\n"
"Salida: {{ checkout_date }}\n"
"Localizador: {{ reservation_locator }}\n"
"Puedes gestionar tu reserva (pago, pre-check-in, datos, etc.) aquí:\n"
"{{ reservation_details_url }}"

#. module: pms_bookai
#: model:pms.notification.template,body:pms_bookai.pms_notification_template_folio_booking_cancellation_whatsapp
msgid ""
"Hello {{ buyer_name }}, your reservation {{ reservation_locator }} at "
"{{ hotel_name }} has been successfully canceled.\n"
"If you need help making a new reservation, we are available."
msgstr ""
"Hola {{ buyer_name }}, tu reserva {{ reservation_locator }} en "
"{{ hotel_name }} ha sido cancelada correctamente.\n"
"Si necesitas ayuda para hacer una nueva reserva, estamos disponibles."

#. module: pms_bookai
#: model:pms.notification.template,body:pms_bookai.pms_notification_template_folio_booking_modification_whatsapp
msgid ""
"Hello {{ buyer_name }}, your reservation {{ reservation_locator }} at "
"{{ hotel_name }} has been updated.\n"
"New check-in: {{ checkin_date }}\n"
"New check-out: {{ checkout_date }}\n"
"You can review the changes here:\n"
"{{ reservation_details_url }}"
msgstr ""
"Hola {{ buyer_name }}, tu reserva {{ reservation_locator }} en "
"{{ hotel_name }} ha sido modificada.\n"
"Nueva entrada: {{ checkin_date }}\n"
"Nueva salida: {{ checkout_date }}\n"
"Puedes revisar los cambios aquí:\n"
"{{ reservation_details_url }}"

#. module: pms_bookai
