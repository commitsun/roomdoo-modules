<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <data noupdate="1">

    <!-- =========================================================
         BOOKAI WHATSAPP RULES (pms.folio)
         ========================================================= -->

    <!-- 1) Booking confirmation (WhatsApp)
         Trigger: when folio state becomes confirm (on_write domain)
         Active: YES
    -->
    <record
      id="pms_property_notification_rule_folio_booking_confirmation_bookai_whatsapp"
      model="pms.property.notification.rule"
    >
      <field name="name">Booking Confirmation (BookAI WhatsApp)</field>
      <field name="active">True</field>
      <field name="pms_property_ids" eval="[(6, 0, [])]" />
      <field
        name="template_id"
        ref="pms_bookai.pms_notification_template_folio_booking_confirmation_whatsapp"
      />
      <field name="target_model_id" ref="pms.model_pms_folio" />

      <field name="rule_type">event</field>
      <field name="event_type">on_write</field>
      <field name="event_domain">[('state', '=', 'confirm')]</field>

      <field name="channel">bookai_whatsapp</field>
      <field name="send_immediately">True</field>
      <field name="max_sends_per_record">1</field>
    </record>

    <!-- 2) Request ETA (WhatsApp)
         Trigger: scheduled 1 day before first_checkin
         Active: YES
         IMPORTANT: assumes pms.folio has first_checkin (as used in your payload)
    -->
    <record
      id="pms_property_notification_rule_folio_request_eta_bookai_whatsapp"
      model="pms.property.notification.rule"
    >
      <field name="name">Request ETA (BookAI WhatsApp)</field>
      <field name="active">True</field>
      <field name="pms_property_ids" eval="[(6, 0, [])]" />
      <field
        name="template_id"
        ref="pms_bookai.pms_notification_template_folio_request_eta_whatsapp"
      />
      <field name="target_model_id" ref="pms.model_pms_folio" />

      <field name="rule_type">scheduled</field>
      <field name="time_field_name">first_checkin</field>
      <field name="offset_days">-1</field>
      <field name="offset_hours">0</field>
      <field name="time_window_minutes">60</field>
      <field name="scheduled_domain">[('state', '=', 'confirm')]</field>

      <field name="channel">bookai_whatsapp</field>
      <field name="send_immediately">True</field>
      <field name="max_sends_per_record">1</field>
    </record>

    <!-- 3) Booking cancellation (WhatsApp)
         Trigger: when folio is cancelled
         NOTE: some implementations use 'cancel', others 'cancelled'
    -->
    <record
      id="pms_property_notification_rule_folio_booking_cancellation_bookai_whatsapp"
      model="pms.property.notification.rule"
    >
      <field name="name">Booking Cancellation (BookAI WhatsApp)</field>
      <field name="active">True</field>
      <field name="pms_property_ids" eval="[(6, 0, [])]" />
      <field
        name="template_id"
        ref="pms_bookai.pms_notification_template_folio_booking_cancellation_whatsapp"
      />
      <field name="target_model_id" ref="pms.model_pms_folio" />

      <field name="rule_type">event</field>
      <field name="event_type">on_write</field>
      <field name="event_domain">[('state', '=', 'cancel')]</field>

      <field name="channel">bookai_whatsapp</field>
      <field name="send_immediately">True</field>
      <field name="max_sends_per_record">1</field>
    </record>

  </data>
</odoo>
