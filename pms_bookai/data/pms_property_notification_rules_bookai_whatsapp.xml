        <record
      id="pms_property_notification_rule_folio_precheckin_payment_reminder_initial_bookai_whatsapp"
      model="pms.property.notification.rule"
    >
            <field name="name">Precheck-in Payment Initial (BookAI WhatsApp)</field>
            <field name="active">True</field>
            <field name="pms_property_ids" eval="[(6, 0, [])]" />
            <field
        name="template_id"
        ref="pms_bookai.pms_notification_template_folio_precheckin_payment_reminder_initial_whatsapp"
      />
            <field name="target_model_id" ref="pms.model_pms_folio" />
            <field name="rule_type">scheduled</field>
            <field name="time_field_name">first_checkin</field>
            <field name="offset_days">-2</field>
            <field name="offset_hours">0</field>
            <field name="scheduled_timing_mode">date_local_hour</field>
            <field name="scheduled_run_hour">20</field>
            <field name="time_window_minutes">60</field>
            <field
        name="scheduled_domain"
      >[('state', '=', 'confirm'), ('checkin_partner_ids.state', 'in', ['dummy', 'draft']), ('pending_amount', '&gt;', 0), '|', ('agency_id', '=', False), ('agency_id.bookai_exclude_payment_reminders', '=', False)]</field>
            <field name="channel">bookai_whatsapp</field>
            <field name="send_immediately">True</field>
            <field name="max_sends_per_record">1</field>
        </record>

