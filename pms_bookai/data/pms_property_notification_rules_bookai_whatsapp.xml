<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">

        <!-- Cleanup legacy noupdate rules replaced by the new matrix -->
        <delete
      model="pms.property.notification.rule"
      search="[('channel', '=', 'bookai_whatsapp'), ('template_id.code', 'in', ['folio_booking_confirmation_bookai_whatsapp_v1', 'folio_booking_cancellation_bookai_whatsapp_v1', 'folio_request_eta_bookai_whatsapp_v1'])]"
    />
        <delete
      model="pms.property.notification.rule"
      search="[('channel', '=', 'bookai_whatsapp'), ('target_model_name', '=', 'pms.folio'), ('rule_type', '=', 'scheduled'), ('scheduled_timing_mode', '=', 'window')]"
    />

        <!-- 1) booking_confirmation_v1 -->
        <record
      id="pms_property_notification_rule_folio_booking_confirmation_bookai_whatsapp_v2"
      model="pms.property.notification.rule"
    >
            <field name="name">Booking Confirmation (BookAI WhatsApp)</field>
            <field name="active">True</field>
            <field name="pms_property_ids" eval="[(6, 0, [])]" />
            <field
        name="template_id"
        ref="pms_bookai.pms_notification_template_folio_booking_confirmation_whatsapp"
      />
            <field name="target_model_id" ref="pms.model_pms_folio" />
            <field name="rule_type">event</field>
            <field name="event_type">on_write</field>
            <field name="event_pre_domain">[('state', '!=', 'confirm')]</field>
            <field name="event_domain">[('state', '=', 'confirm')]</field>
            <field
        name="on_write_field_ids"
        eval="[(6, 0, [ref('pms.field_pms_folio__state')])]"
      />
            <field name="channel">bookai_whatsapp</field>
            <field name="send_immediately">True</field>
            <field name="max_sends_per_record">1</field>
        </record>

        <!-- 2) booking_modification_v1 -->
        <record
      id="pms_property_notification_rule_folio_booking_modification_bookai_whatsapp"
      model="pms.property.notification.rule"
    >
            <field name="name">Booking Modification (BookAI WhatsApp)</field>
            <field name="active">True</field>
            <field name="pms_property_ids" eval="[(6, 0, [])]" />
            <field
        name="template_id"
        ref="pms_bookai.pms_notification_template_folio_booking_modification_whatsapp"
      />
            <field name="target_model_id" ref="pms.model_pms_folio" />
            <field name="rule_type">event</field>
            <field name="event_type">on_write</field>
            <field name="event_pre_domain">[('state', '=', 'confirm')]</field>
            <field
        name="event_domain"
      >[('state', '=', 'confirm'), ('last_checkout', '>', (datetime.date.today().isoformat()))]</field>
            <field
        name="on_write_field_ids"
        eval="[(6, 0, [ref('pms.field_pms_folio__first_checkin'), ref('pms.field_pms_folio__last_checkout'), ref('pms.field_pms_folio__reservation_ids')])]"
      />
            <field name="channel">bookai_whatsapp</field>
            <field name="send_immediately">True</field>
            <field name="max_sends_per_record">0</field>
        </record>

