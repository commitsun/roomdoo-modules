<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">

    <record id="ir_cron_sync_sdk_tools" model="ir.cron">
        <field name="name">BooKAI: Sync SDK Tools</field>
        <field name="model_id" ref="model_bookai_tool" />
        <field name="state">code</field>
        <field name="code">model.action_sync_sdk_tools()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="'2026-04-22 02:00:00'" />
        <field name="numbercall">-1</field>
        <field name="active" eval="True" />
    </record>

    <record id="ir_cron_mcp_health_check" model="ir.cron">
        <field name="name">BooKAI: MCP Health Check</field>
        <field name="model_id" ref="model_bookai_mcp_server" />
        <field name="state">code</field>
        <field name="code">model.action_health_check_all()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True" />
    </record>

</odoo>
