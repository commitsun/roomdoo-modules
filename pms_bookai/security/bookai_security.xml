<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- ============================================================ -->
    <!-- Category & Groups                                            -->
    <!-- ============================================================ -->

    <record id="module_category_bookai" model="ir.module.category">
        <field name="name">BooKAI</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_bookai_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_bookai" />
    </record>

    <record id="group_bookai_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_bookai" />
        <field name="implied_ids" eval="[(4, ref('group_bookai_user'))]" />
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules — BooKAI User                                   -->
    <!-- ============================================================ -->

    <record id="rule_bookai_agent_user" model="ir.rule">
        <field name="name">BooKAI Agent: user sees assigned only</field>
        <field name="model_id" ref="model_bookai_agent" />
        <field name="domain_force">[('allowed_user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_bookai_kb_document_user" model="ir.rule">
        <field name="name">BooKAI KB Document: user sees docs of assigned agents</field>
        <field name="model_id" ref="model_bookai_kb_document" />
        <field
      name="domain_force"
    >[('agent_ids.allowed_user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_bookai_llm_account_user" model="ir.rule">
        <field
      name="name"
    >BooKAI LLM Account: user sees accounts of assigned agents</field>
        <field name="model_id" ref="model_bookai_llm_account" />
        <field
      name="domain_force"
    >[('bookai_agent_ids.allowed_user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_bookai_agent_usage_user" model="ir.rule">
        <field name="name">BooKAI Usage: user sees usage of assigned agents</field>
        <field name="model_id" ref="model_bookai_agent_usage" />
        <field
      name="domain_force"
    >[('agent_id.allowed_user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules — BooKAI Admin (unrestricted)                   -->
    <!-- ============================================================ -->

    <record id="rule_bookai_agent_admin" model="ir.rule">
        <field name="name">BooKAI Agent: admin full access</field>
        <field name="model_id" ref="model_bookai_agent" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_admin'))]" />
    </record>

    <record id="rule_bookai_kb_document_admin" model="ir.rule">
        <field name="name">BooKAI KB Document: admin full access</field>
        <field name="model_id" ref="model_bookai_kb_document" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_admin'))]" />
    </record>

    <record id="rule_bookai_llm_account_admin" model="ir.rule">
        <field name="name">BooKAI LLM Account: admin full access</field>
        <field name="model_id" ref="model_bookai_llm_account" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_admin'))]" />
    </record>

    <record id="rule_bookai_agent_usage_admin" model="ir.rule">
        <field name="name">BooKAI Usage: admin full access</field>
        <field name="model_id" ref="model_bookai_agent_usage" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_admin'))]" />
    </record>

    <record id="rule_bookai_wa_translation_user" model="ir.rule">
        <field name="name">BooKAI WA Translation: user read</field>
        <field name="model_id" ref="model_bookai_whatsapp_translation" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_bookai_wa_translation_admin" model="ir.rule">
        <field name="name">BooKAI WA Translation: admin full access</field>
        <field name="model_id" ref="model_bookai_whatsapp_translation" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_bookai_admin'))]" />
    </record>

    <!-- Tools & Audit Log: no record rules (access controlled by BookAI) -->
    <!-- ir.model.access.csv gives base.group_user read, admin CRUD -->

</odoo>
