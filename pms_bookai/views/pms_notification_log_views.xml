<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_pms_notification_log_form_bookai" model="ir.ui.view">
        <field name="name">pms.notification.log.form.bookai</field>
        <field name="model">pms.notification.log</field>
        <field
      name="inherit_id"
      ref="pms_notifications.view_pms_notification_log_form"
    />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='external_payload']" position="after">
                <separator
          string="WhatsApp Details"
          attrs="{'invisible': [('channel', '!=', 'bookai_whatsapp')]}"
        />
                <group attrs="{'invisible': [('channel', '!=', 'bookai_whatsapp')]}">
                    <field name="whatsapp_phone" />
                    <field name="whatsapp_country" />
                    <field name="whatsapp_template_parameters" widget="ace" />
                    <field name="whatsapp_body_preview" widget="text" readonly="1" />
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page
          string="BookAI Debug"
          name="bookai_debug"
          groups="base.group_system"
          attrs="{'invisible': [('channel', '!=', 'bookai_whatsapp')]}"
        >
                    <group>
                        <field name="bookai_last_http_status" readonly="1" />
                    </group>
                    <group>
                        <field
              name="bookai_last_request_headers"
              widget="ace"
              readonly="1"
            />
                    </group>
                    <group>
                        <field
              name="bookai_last_request_payload"
              widget="ace"
              readonly="1"
            />
                    </group>
                    <group>
                        <field
              name="bookai_last_response_body"
              widget="ace"
              readonly="1"
            />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
