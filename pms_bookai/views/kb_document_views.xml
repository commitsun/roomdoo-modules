<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Tree -->
    <record id="view_bookai_kb_document_tree" model="ir.ui.view">
        <field name="name">bookai.kb.document.tree</field>
        <field name="model">bookai.kb.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="description" optional="show" />
                <field name="source_type" />
                <field name="doc_type" />
                <field
          name="pms_property_ids"
          widget="many2many_tags"
          optional="show"
        />
                <field name="inject_always" />
                <field name="vectorize" />
                <field name="vector_status" />
                <field name="active" invisible="1" />
            </tree>
        </field>
    </record>

    <!-- KB Binding tree (embedded in document form) -->
    <record id="view_bookai_kb_document_binding_tree" model="ir.ui.view">
        <field name="name">bookai.kb.document.binding.tree</field>
        <field name="model">bookai.agent.kb.binding</field>
        <field name="arch" type="xml">
            <tree string="Agent Bindings" editable="bottom">
                <field name="agent_id" />
                <field name="description_override" optional="show" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <!-- Form -->
    <record id="view_bookai_kb_document_form" model="ir.ui.view">
        <field name="name">bookai.kb.document.form</field>
        <field name="model">bookai.kb.document</field>
        <field name="arch" type="xml">
            <form string="KB Document">
                <sheet>
                    <div class="oe_button_box" name="button_box" />
                    <widget
            name="web_ribbon"
            title="Archived"
            bg_color="bg-danger"
            attrs="{'invisible': [('active', '=', True)]}"
          />
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Document name..." />
                        </h1>
                        <field
              name="description"
              placeholder="Short description for agents..."
            />
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="source_type" />
                            <field name="doc_type" />
                            <field name="active" invisible="1" />
                        </group>
                        <group string="Behaviour">
                            <field name="inject_always" />
                            <field name="vectorize" />
                            <field name="vector_status" readonly="1" />
                        </group>
                    </group>
                    <group string="Property Scope">
                        <field
              name="pms_property_ids"
              widget="many2many_tags"
              nolabel="1"
              colspan="2"
              placeholder="Empty = available for all properties"
            />
                    </group>
                    <group string="Content">
                        <field
              name="content"
              nolabel="1"
              colspan="2"
              attrs="{'invisible': [('source_type', '!=', 'markdown')]}"
            />
                        <field
              name="attachment_id"
              attrs="{'invisible': [('source_type', '!=', 'pdf')]}"
            />
                        <field
              name="source_url"
              widget="url"
              attrs="{'invisible': [('source_type', '!=', 'url')]}"
            />
                    </group>
                    <notebook>
                        <page string="Agents" name="agents">
                            <field name="kb_binding_ids">
                                <tree
                  ref="pms_bookai.view_bookai_kb_document_binding_tree"
                />
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bookai_kb_document" model="ir.actions.act_window">
        <field name="name">KB Documents</field>
        <field name="res_model">bookai.kb.document</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
