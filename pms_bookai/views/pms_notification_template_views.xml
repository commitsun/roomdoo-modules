<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- BookAI params tree used inside the template form -->
    <record id="view_pms_notification_template_bookai_param_tree" model="ir.ui.view">
        <field name="name">pms.notification.template.bookai.param.tree</field>
        <field name="model">pms.notification.template.bookai.param</field>
        <field name="arch" type="xml">
            <tree string="BookAI Parameters" editable="bottom">
                <field name="target_model_name" invisible="1" />
                <field name="sequence" widget="handle" />
                <field name="key" />
                <field name="description" />
                <field name="example_value" placeholder="e.g. John Smith" />
                <field name="value_type" />
                <field
          name="field_id"
          attrs="{
                        'invisible': [('value_type', '!=', 'field')],
                        'required': [('value_type', '=', 'field')]
                    }"
          domain="[
                        ('model', '=', target_model_name),
                        ('ttype', 'not in', ('one2many', 'many2many', 'binary'))
                    ]"
        />
                <field
          name="value_inline_tmpl"
          attrs="{
                        'invisible': [('value_type', 'not in', ('inline', 'qweb'))],
                        'required': [('value_type', 'in', ('inline', 'qweb'))]
                    }"
        />
                <field
          name="value_literal"
          attrs="{
                        'invisible': [('value_type', '!=', 'literal')],
                        'required': [('value_type', '=', 'literal')]
                    }"
        />
            </tree>
        </field>
    </record>

    <!-- BookAI WhatsApp translation tree (embedded in template form) -->
    <record id="view_bookai_whatsapp_translation_tree" model="ir.ui.view">
        <field name="name">bookai.whatsapp.translation.tree</field>
        <field name="model">bookai.whatsapp.translation</field>
        <field name="arch" type="xml">
            <tree
        string="WhatsApp Translations"
        create="false"
        delete="false"
        editable="bottom"
      >
                <field name="wa_account_id" />
                <field name="language" />
                <field name="active" />
                <field
          name="meta_status"
          widget="badge"
          decoration-success="meta_status == 'approved'"
          decoration-warning="meta_status == 'pending'"
          decoration-danger="meta_status in ('rejected','error')"
          decoration-muted="meta_status == 'draft'"
        />
                <field name="meta_template_id" optional="show" />
            </tree>
        </field>
    </record>

    <!-- Inherit PMS notification template form to add a BookAI WhatsApp tab -->
    <record id="view_pms_notification_template_form_inherit_bookai" model="ir.ui.view">
        <field name="name">pms.notification.template.form.inherit.bookai</field>
        <field name="model">pms.notification.template</field>
        <field
      name="inherit_id"
      ref="pms_notifications.view_pms_notification_template_form"
    />
        <field name="arch" type="xml">

            <!-- Ensure target_model_name is present (invisible) for domains -->
            <xpath expr="//form/sheet" position="inside">
                <field name="target_model_name" invisible="1" />
            </xpath>

            <xpath expr="//form/sheet" position="inside">
                <notebook>
                    <page string="BookAI WhatsApp">

                        <!-- Identity & recipient -->
                        <group>
                            <group>
                                <field name="bookai_template_code" />
                                <field name="bookai_category" />
                                <field
                  name="bookai_language_tmpl"
                  placeholder="{{ object.lang or user.lang }}"
                />
                            </group>
                            <group>
                                <field
                  name="bookai_recipient_phone_tmpl"
                  placeholder="{{ object.partner_id.mobile or object.mobile }}"
                />
                                <field
                  name="bookai_recipient_name_tmpl"
                  placeholder="{{ object.partner_id.name or object.partner_name }}"
                />
                            </group>
                        </group>

                        <!-- Folio reference -->
                        <group>
                            <field
                name="bookai_origin_folio_id_tmpl"
                placeholder="{{ (object if object._name == 'pms.folio' else object.folio_id).id }}"
              />
                        </group>

                        <!-- Header -->
                        <group>
                            <field
                name="bookai_header_text"
                placeholder="Optional header..."
              />
                        </group>

                        <!-- Body -->
                        <group>
                            <field
                name="body"
                widget="text"
                placeholder="Hello {{ buyer_name }}, your reservation {{ reservation_locator }}..."
              />
                        </group>

                        <!-- Footer + Buttons -->
                        <group>
                            <group>
                                <field
                  name="bookai_footer_text"
                  placeholder="Optional footer..."
                />
                            </group>
                            <group>
                                <field
                  name="bookai_button_texts"
                  placeholder='[{"type":"URL","text":"Check-in","url":"https://..."}]'
                />
                            </group>
                        </group>

                        <!-- Parameters -->
                        <group string="Template Parameters">
                            <field
                name="bookai_param_ids"
                context="{'default_template_id': active_id}"
              >
                                <tree
                  ref="pms_bookai.view_pms_notification_template_bookai_param_tree"
                />
                            </field>
                        </group>

                        <!-- Example record + generate -->
                        <group string="Meta Examples">
                            <group>
                                <field name="bookai_example_record_id" />
                                <field name="bookai_example_record_name" />
                            </group>
                            <group>
                                <button
                  name="action_select_example_record"
                  type="object"
                  string="Select Record"
                  class="btn-secondary"
                  icon="fa-search"
                />
                                <button
                  name="action_generate_examples"
                  type="object"
                  string="Generate Examples"
                  class="btn-secondary"
                  icon="fa-magic"
                  attrs="{'invisible': [('bookai_example_record_id', '=', 0)]}"
                />
                            </group>
                        </group>

                        <!-- Body example preview -->
                        <group
              string="Body Example Preview"
              attrs="{'invisible': [('bookai_body_example', '=', False)]}"
            >
                            <field name="bookai_body_example" readonly="1" />
                        </group>

                        <!-- Translations -->
                        <group string="WhatsApp Translations (auto-managed on sync)">
                            <field
                name="bookai_translation_ids"
                context="{'default_template_id': active_id}"
              >
                                <tree
                  ref="pms_bookai.view_bookai_whatsapp_translation_tree"
                />
                            </field>
                        </group>

                        <!-- Sync buttons -->
                        <div
              class="mt16 mb16"
              attrs="{'invisible': [('bookai_template_code', '=', False)]}"
            >
                            <button
                name="action_sync_to_bookai"
                type="object"
                string="Sync to BooKAI"
                class="btn-primary"
                icon="fa-cloud-upload"
              />
                            <button
                name="action_check_bookai_status"
                type="object"
                string="Check Status"
                class="btn-secondary ms-2"
                icon="fa-refresh"
              />
                        </div>

                        <!-- Tip -->
                        <group>
                            <separator string="Tip" />
                            <div>
                                <p>
                                    Use <strong>QWeb Template</strong> params for
                                    loops/conditionals (t-if, t-foreach), and keep body
                                    placeholders as <code>{{ parameter_key }}</code>.
                                    The final rendered output is converted to
                                    WhatsApp-safe text formatting.
                                </p>
                            </div>
                        </group>

                    </page>
                </notebook>
            </xpath>

        </field>
    </record>

</odoo>
