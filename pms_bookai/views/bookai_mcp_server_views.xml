<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Tree -->
    <record id="view_bookai_mcp_server_tree" model="ir.ui.view">
        <field name="name">bookai.mcp.server.tree</field>
        <field name="model">bookai.mcp.server</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="transport_type" />
                <field
          name="connection_status"
          widget="badge"
          decoration-success="connection_status == 'connected'"
          decoration-danger="connection_status == 'error'"
          decoration-muted="connection_status == 'disconnected'"
        />
                <field name="last_discovery_at" />
                <field name="active" invisible="1" />
            </tree>
        </field>
    </record>

    <!-- Form -->
    <record id="view_bookai_mcp_server_form" model="ir.ui.view">
        <field name="name">bookai.mcp.server.form</field>
        <field name="model">bookai.mcp.server</field>
        <field name="arch" type="xml">
            <form string="MCP Server">
                <header>
                    <button
            name="action_connect"
            type="object"
            string="Connect"
            class="btn-primary"
            icon="fa-plug"
            attrs="{'invisible': [('connection_status', '=', 'connected')]}"
          />
                    <button
            name="action_discover_tools"
            type="object"
            string="Discover Tools"
            class="btn-primary"
            icon="fa-download"
          />
                    <button
            name="action_check_status"
            type="object"
            string="Check Status"
            icon="fa-heartbeat"
          />
                    <button
            name="action_disconnect"
            type="object"
            string="Disconnect"
            icon="fa-power-off"
            attrs="{'invisible': [('connection_status', '!=', 'connected')]}"
          />
                    <field
            name="connection_status"
            widget="statusbar"
            statusbar_visible="disconnected,connected"
          />
                </header>
                <sheet>
                    <widget
            name="web_ribbon"
            title="Archived"
            bg_color="bg-danger"
            attrs="{'invisible': [('active', '=', True)]}"
          />
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Server name..." />
                        </h1>
                    </div>
                    <group>
                        <group string="Transport">
                            <field name="transport_type" />
                            <!-- stdio fields -->
                            <field
                name="command"
                placeholder="npx"
                attrs="{'invisible': [('transport_type', '!=', 'stdio')], 'required': [('transport_type', '=', 'stdio')]}"
              />
                            <field
                name="args"
                placeholder="@anthropic/mcp-server-brave-search"
                attrs="{'invisible': [('transport_type', '!=', 'stdio')]}"
              />
                            <field
                name="env_vars"
                placeholder='{"API_KEY": "xxx"}'
                attrs="{'invisible': [('transport_type', '!=', 'stdio')]}"
              />
                            <!-- http fields -->
                            <field
                name="url"
                placeholder="https://mcp-server.example.com"
                attrs="{'invisible': [('transport_type', '!=', 'http')], 'required': [('transport_type', '=', 'http')]}"
              />
                            <field
                name="auth_type"
                attrs="{'invisible': [('transport_type', '!=', 'http')]}"
              />
                            <field
                name="api_key"
                password="True"
                attrs="{'invisible': ['|', ('transport_type', '!=', 'http'), ('auth_type', '=', 'none')]}"
              />
                        </group>
                        <group string="Status">
                            <field name="last_discovery_at" />
                            <field name="status_message" />
                            <field name="active" invisible="1" />
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2" />
                    </group>
                    <notebook>
                        <page string="Tools" name="tools">
                            <field name="tool_ids" readonly="1">
                                <tree>
                                    <field name="name" />
                                    <field name="description" />
                                    <field name="active" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bookai_mcp_server" model="ir.actions.act_window">
        <field name="name">MCP Servers</field>
        <field name="res_model">bookai.mcp.server</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
