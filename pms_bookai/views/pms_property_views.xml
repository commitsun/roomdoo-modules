<?xml version="1.0" encoding="utf-8" ?>
<odoo>

  <record id="view_pms_property_form_inherit_bookai" model="ir.ui.view">
    <field name="name">pms.property.form.inherit.bookai</field>
    <field name="model">pms.property</field>
    <field name="inherit_id" ref="pms.pms_property_views_form" />
    <field name="arch" type="xml">

        <xpath expr="//sheet/notebook" position="inside">
            <page string="BookAI" name="bookai">
                <group>
                    <group>
                        <field name="bookai_mode" />
                        <field name="external_code" />
                    </group>
                    <group>
                        <field name="bookai_online_selling" />
                        <field
                name="bookai_sale_channel_id"
                attrs="{'invisible': [('bookai_online_selling', '=', False)], 'required': [('bookai_online_selling', '=', True)]}"
              />
                    </group>
                </group>
                <group string="WhatsApp Channel">
                    <group>
                        <field name="bookai_wa_phone_id" />
                    </group>
                </group>
                <group string="App">
                    <group>
                        <field
                name="bookai_app_url"
                placeholder="https://bookai.example.com"
              />
                    </group>
                </group>
                <group string="Escalation">
                    <group>
                        <field name="bookai_escalation_timeout" />
                        <field name="bookai_escalation_template_id" />
                    </group>
                    <group>
                        <field
                name="bookai_escalation_user_ids"
                widget="many2many_tags"
              />
                    </group>
                </group>
            </page>
        </xpath>

    </field>
  </record>

  <record id="view_pms_property_tree_inherit_bookai" model="ir.ui.view">
    <field name="name">pms.property.tree.inherit.bookai</field>
    <field name="model">pms.property</field>
    <!-- Adjust this inherit_id too -->
    <field name="inherit_id" ref="pms.pms_property_views_tree" />
    <field name="arch" type="xml">
      <xpath expr="//tree" position="inside">
        <field name="bookai_mode" />
      </xpath>
    </field>
  </record>

</odoo>
