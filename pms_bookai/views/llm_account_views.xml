<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Tree -->
    <record id="view_bookai_llm_account_tree" model="ir.ui.view">
        <field name="name">bookai.llm.account.tree</field>
        <field name="model">bookai.llm.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="provider" />
                <field name="default_model" />
                <field name="tokens_used_month" />
                <field name="monthly_token_limit" />
                <field name="active" invisible="1" />
            </tree>
        </field>
    </record>

    <!-- Form -->
    <record id="view_bookai_llm_account_form" model="ir.ui.view">
        <field name="name">bookai.llm.account.form</field>
        <field name="model">bookai.llm.account</field>
        <field name="arch" type="xml">
            <form string="LLM Account">
                <sheet>
                    <div class="oe_button_box" name="button_box" />
                    <widget
            name="web_ribbon"
            title="Archived"
            bg_color="bg-danger"
            attrs="{'invisible': [('active', '=', True)]}"
          />
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Account name..." />
                        </h1>
                    </div>
                    <group>
                        <group string="Provider">
                            <field name="provider" />
                            <field name="api_base_url" />
                            <field name="default_model" />
                        </group>
                        <group string="Credentials &amp; Limits">
                            <field name="api_key" password="True" />
                            <field name="monthly_token_limit" />
                            <field name="tokens_used_month" />
                            <field name="active" invisible="1" />
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bookai_llm_account" model="ir.actions.act_window">
        <field name="name">LLM Accounts</field>
        <field name="res_model">bookai.llm.account</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
