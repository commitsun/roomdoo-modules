<odoo>
    <record id="availability_plan_rule_wubook_connector_view_form" model="ir.ui.view">
        <field
            name="name"
        >pms.availability.plan.rule.wubook.connector.binds.form</field>
        <field name="model">pms.availability.plan.rule</field>
        <field name="inherit_id" ref="connector_pms.availability_plan_rule_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='connector']">
                <separator string="Wubook" />
                <field name="channel_wubook_bind_ids" nolabel="1">
                    <tree editable="bottom">
                        <field
                            name="backend_id"
                            attrs="{'readonly': [('id', '!=', False)]}"
                        />
                        <field name="external_id" />
                        <field name="no_ota" />
                        <field name="sync_date" />
                        <field name="synced_export" />
                        <field name="sync_date_export" />
                    </tree>
                </field>
            </xpath>
        </field>
    </record>
</odoo>
