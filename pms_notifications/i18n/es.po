#. module: pms_notifications
#: model:mail.template,body_html:pms_notifications.mail_template_pms_folio_confirmation
msgid ""
"<div style=\"margin:0; padding:0;\">\n"
"                <t t-set=\"o\" t-value=\"object\"></t>\n"
"                <t t-set=\"property\" t-value=\"o.pms_property_id\"></t>\n"
"                <t t-set=\"customer\" t-value=\"o.partner_id\"></t>\n"
"                <t t-set=\"company\" t-value=\"o.company_id\"></t>\n"
"                <t t-set=\"currency\" t-value=\"o.currency_id\"></t>\n"
"\n"
"                <p style=\"margin: 0 0 12px 0;\">\n"
"                    <t t-if=\"customer and customer.name\">\n"
"                        Hello <strong><t t-out=\"customer.name\"></t></"
"strong>,\n"
"                    </t>\n"
"                    <t t-else=\"\">Hello,</t>\n"
"                    <br>\n"
"                    Your reservation has been confirmed.\n"
"                </p>\n"
"\n"
"                <t t-if=\"property and property.welcome_message\">\n"
"                    <div style=\"margin: 0 0 14px 0; padding: 10px 12px; "
"border-left: 3px solid #ddd; background: #fafafa;\">\n"
"                        <t t-out=\"property.welcome_message\"></t>\n"
"                    </div>\n"
"                </t>\n"
"\n"
"                <h3 style=\"margin: 0 0 8px 0; padding: 0; font-size: 16px; "
"font-weight: 600;\">Booking summary</h3>\n"
"\n"
"                <table style=\"width: 100%; border-collapse: collapse; "
"margin: 0 0 16px 0;\">\n"
"                    <tbody>\n"
"                        <tr>\n"
"                            <td style=\"padding: 2px 0; width: 170px; color: "
"#666;\">Booking reference</td>\n"
"                            <td style=\"padding: 2px 0;\"><t t-out=\"o.name "
"or ''\"></t></td>\n"
"                        </tr>\n"
"                        <tr>\n"
"                            <td style=\"padding: 2px 0; width: 170px; color: "
"#666;\">Check-in</td>\n"
"                            <td style=\"padding: 2px 0;\">\n"
"                                <t t-out=\"format_date(o.first_checkin) if o."
"first_checkin else ''\"></t>\n"
"                                <t t-if=\"property and property."
"checkin_time_info\">\n"
"                                     (<t t-out=\"property."
"checkin_time_info\"></t>)\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                        <tr>\n"
"                            <td style=\"padding: 2px 0; width: 170px; color: "
"#666;\">Check-out</td>\n"
"                            <td style=\"padding: 2px 0;\">\n"
"                                <t t-out=\"format_date(o.last_checkout) if o."
"last_checkout else ''\"></t>\n"
"                                <t t-if=\"property and property."
"checkout_time_info\">\n"
"                                     (<t t-out=\"property."
"checkout_time_info\"></t>)\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                        <tr>\n"
"                            <td style=\"padding: 2px 0; width: 170px; color: "
"#666;\">Total</td>\n"
"                            <td style=\"padding: 2px 0;\">\n"
"                                <t t-out=\"format_amount(o.amount_total, "
"currency)\"></t>\n"
"                            </td>\n"
"                        </tr>\n"
"                        <tr>\n"
"                            <td style=\"padding: 2px 0; width: 170px; color: "
"#666;\">Amount due</td>\n"
"                            <td style=\"padding: 2px 0;\">\n"
"                                <t t-out=\"format_amount(o.pending_amount, "
"currency)\"></t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"\n"
"                <h3 style=\"margin: 0 0 8px 0; padding: 0; font-size: 16px; "
"font-weight: 600;\">Rooms</h3>\n"
"\n"
"                <t t-if=\"o.reservation_ids\">\n"
"                    <t t-foreach=\"o.reservation_ids\" t-as=\"r\">\n"
"                        <t t-set=\"room_type\" t-value=\"r.room_type_id\"></"
"t>\n"
"                        <t t-set=\"rate\" t-value=\"r.pricelist_id\"></t>\n"
"                        <!-- In your case the cancellation rule is on "
"pricelist (NOT on reservation) -->\n"
"                        <t t-set=\"cancel_rule\" t-value=\"rate."
"cancelation_rule_id\"></t>\n"
"\n"
"                        <div style=\"margin: 0 0 12px 0; padding: 12px; "
"border: 1px solid #eee; border-radius: 8px;\">\n"
"                            <div style=\"margin: 0 0 8px 0;\">\n"
"                                <strong>\n"
"                                    <t t-if=\"room_type and room_type."
"guest_display_name\"><t t-out=\"room_type.guest_display_name\"></t></t>\n"
"                                    <t t-elif=\"room_type and room_type."
"name\"><t t-out=\"room_type.name\"></t></t>\n"
"                                    <t t-else=\"\">Room</t>\n"
"                                </strong>\n"
"                            </div>\n"
"\n"
"                            <table style=\"width: 100%; border-collapse: "
"collapse;\">\n"
"                                <tbody>\n"
"                                    <tr>\n"
"                                        <td style=\"padding: 2px 0; width: "
"170px; color: #666;\">Dates</td>\n"
"                                        <td style=\"padding: 2px 0;\">\n"
"                                            <t t-out=\"format_date(r."
"checkin) if r.checkin else ''\"></t>\n"
"                                             → \n"
"                                            <t t-out=\"format_date(r."
"checkout) if r.checkout else ''\"></t>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                    <tr>\n"
"                                        <td style=\"padding: 2px 0; width: "
"170px; color: #666;\">Guests</td>\n"
"                                        <td style=\"padding: 2px 0;\">\n"
"                                            <t t-out=\"(r.adults or 0)\"></"
"t> adults\n"
"                                            <t t-if=\"(r.children or 0) &gt; "
"0\">, <t t-out=\"r.children\"></t> children</t>\n"
"                                        </td>\n"
"                                    </tr>\n"
"\n"
"                                    <t t-if=\"rate\">\n"
"                                        <tr>\n"
"                                            <td style=\"padding: 2px 0; "
"width: 170px; color: #666;\">Rate</td>\n"
"                                            <td style=\"padding: 2px 0;\">\n"
"                                                <t t-if=\"rate."
"guest_rate_name\"><t t-out=\"rate.guest_rate_name\"></t></t>\n"
"                                                <t t-else=\"\"><t t-"
"out=\"rate.name\"></t></t>\n"
"                                            </td>\n"
"                                        </tr>\n"
"                                    </t>\n"
"\n"
"                                    <t t-if=\"room_type and room_type."
"guest_short_description\">\n"
"                                        <tr>\n"
"                                            <td style=\"padding: 2px 0; "
"width: 170px; color: #666;\">Room details</td>\n"
"                                            <td style=\"padding: 2px 0;\"><t "
"t-out=\"room_type.guest_short_description\"></t></td>\n"
"                                        </tr>\n"
"                                    </t>\n"
"\n"
"                                    <t t-if=\"room_type and room_type."
"amenities_summary\">\n"
"                                        <tr>\n"
"                                            <td style=\"padding: 2px 0; "
"width: 170px; color: #666;\">Amenities</td>\n"
"                                            <td style=\"padding: 2px 0;\"><t "
"t-out=\"room_type.amenities_summary\"></t></td>\n"
"                                        </tr>\n"
"                                    </t>\n"
"\n"
"                                    <t t-if=\"r.service_ids\">\n"
"                                        <tr>\n"
"                                            <td style=\"padding: 2px 0; "
"width: 170px; color: #666;\">Services</td>\n"
"                                            <td style=\"padding: 2px 0;\">\n"
"                                                <t t-foreach=\"r."
"service_ids\" t-as=\"s\">\n"
"                                                    <span style=\"display: "
"inline-block; margin: 0 6px 6px 0; padding: 2px 8px; border: 1px solid #eee; "
"border-radius: 999px;\">\n"
"                                                        <t t-out=\"s."
"name\"></t>\n"
"                                                    </span>\n"
"                                                </t>\n"
"                                            </td>\n"
"                                        </tr>\n"
"                                    </t>\n"
"                                </tbody>\n"
"                            </table>\n"
"\n"
"                            <t t-if=\"rate and rate."
"guest_rate_description\">\n"
"                                <div style=\"margin: 10px 0 0 0; color: #444;"
"\">\n"
"                                    <strong>Rate details:</strong>\n"
"                                    <div><t t-out=\"rate."
"guest_rate_description\"></t></div>\n"
"                                </div>\n"
"                            </t>\n"
"\n"
"                            <t t-if=\"rate and rate.payment_terms_text\">\n"
"                                <div style=\"margin: 10px 0 0 0; color: #444;"
"\">\n"
"                                    <strong>Payment terms:</strong>\n"
"                                    <div><t t-out=\"rate."
"payment_terms_text\"></t></div>\n"
"                                </div>\n"
"                            </t>\n"
"\n"
"                            <t t-if=\"rate and rate."
"cancellation_terms_text_override\">\n"
"                                <div style=\"margin: 10px 0 0 0; color: #444;"
"\">\n"
"                                    <strong>Cancellation policy:</strong>\n"
"                                    <div><t t-out=\"rate."
"cancellation_terms_text_override\"></t></div>\n"
"                                </div>\n"
"                            </t>\n"
"                            <t t-elif=\"cancel_rule and cancel_rule."
"short_policy_text\">\n"
"                                <div style=\"margin: 10px 0 0 0; color: #444;"
"\">\n"
"                                    <strong>Cancellation policy:</strong>\n"
"                                    <div><t t-out=\"cancel_rule."
"short_policy_text\"></t></div>\n"
"                                </div>\n"
"                            </t>\n"
"                        </div>\n"
"                    </t>\n"
"                </t>\n"
"                <t t-else=\"\">\n"
"                    <p style=\"margin: 0 0 16px 0;\">No rooms were found for "
"this booking.</p>\n"
"                </t>\n"
"\n"
"                <t t-if=\"property and (property.arrival_instructions or "
"property.parking_info or property.prearrival_extra_info or property."
"digital_checkin_help)\">\n"
"                    <h3 style=\"margin: 0 0 8px 0; padding: 0; font-size: "
"16px; font-weight: 600;\">Useful information</h3>\n"
"\n"
"                    <t t-if=\"property.arrival_instructions\">\n"
"                        <div style=\"margin: 0 0 10px 0;\">\n"
"                            <strong>Arrival instructions</strong><br>\n"
"                            <t t-out=\"property.arrival_instructions\"></t>\n"
"                        </div>\n"
"                    </t>\n"
"\n"
"                    <t t-if=\"property.parking_info\">\n"
"                        <div style=\"margin: 0 0 10px 0;\">\n"
"                            <strong>Parking</strong><br>\n"
"                            <t t-out=\"property.parking_info\"></t>\n"
"                        </div>\n"
"                    </t>\n"
"\n"
"                    <t t-if=\"property.digital_checkin_help\">\n"
"                        <div style=\"margin: 0 0 10px 0;\">\n"
"                            <strong>Digital check-in</strong><br>\n"
"                            <t t-out=\"property.digital_checkin_help\"></t>\n"
"                        </div>\n"
"                    </t>\n"
"\n"
"                    <t t-if=\"property.prearrival_extra_info\">\n"
"                        <div style=\"margin: 0 0 10px 0;\">\n"
"                            <strong>Before you arrive</strong><br>\n"
"                            <t t-out=\"property.prearrival_extra_info\"></"
"t>\n"
"                        </div>\n"
"                    </t>\n"
"                </t>\n"
"\n"
"                <t t-if=\"property and property.critical_contact_phone\">\n"
"                    <p style=\"margin: 12px 0 0 0;\">\n"
"                        For urgent matters, you can reach us at:\n"
"                        <strong><t t-out=\"property."
"critical_contact_phone\"></t></strong>\n"
"                    </p>\n"
"                </t>\n"
"\n"
"                <t t-if=\"company and (company.privacy_policy_text or "
"company.terms_and_conditions_text or company.legal_notice_text)\">\n"
"                    <div style=\"margin-top: 18px; padding-top: 12px; border-"
"top: 1px solid #eee; color: #666; font-size: 12px;\">\n"
"                        <t t-if=\"company.privacy_policy_text\">\n"
"                            <div style=\"margin: 0 0 8px 0;\"><t t-"
"out=\"company.privacy_policy_text\"></t></div>\n"
"                        </t>\n"
"                        <t t-if=\"company.terms_and_conditions_text\">\n"
"                            <div style=\"margin: 0 0 8px 0;\"><t t-"
"out=\"company.terms_and_conditions_text\"></t></div>\n"
"                        </t>\n"
"                        <t t-if=\"company.legal_notice_text\">\n"
"                            <div style=\"margin: 0;\"><t t-out=\"company."
"legal_notice_text\"></t></div>\n"
"                        </t>\n"
"                    </div>\n"
"                </t>\n"
"\n"
"                <t t-if=\"property and property.default_email_signature\">\n"
"                    <div style=\"margin-top: 18px;\">\n"
"                        <t t-raw=\"property.default_email_signature\"></t>\n"
"                    </div>\n"
"                </t>\n"
"            </div>\n"
"        "
