<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <data noupdate="0">

        <!-- Booking confirmation email -->
        <record
      id="pms_property_notification_rule_confirmation_email"
      model="pms.property.notification.rule"
    >
        <field name="name">Confirmation Notification (Email)</field>
        <field name="active">True</field>
        <field
        name="template_id"
        ref="pms_notifications.pms_notification_template_folio_confirmation_email"
      />
        <field name="target_model_id" ref="pms.model_pms_folio" />
        <field name="rule_type">event</field>
        <field name="event_type">on_write</field>
        <field name="event_domain">[('state', '=', 'confirm')]</field>
        <field name="channel">email</field>
        <field name="send_immediately">True</field>
        <field name="max_sends_per_record">1</field>
        </record>

        <!-- Pre-arrival: 3 days before check-in -->
        <record
      id="pms_property_notification_rule_prearrival_email"
      model="pms.property.notification.rule"
    >
            <field name="name">Pre-arrival Information (Email)</field>
            <field name="active">True</field>
            <field name="pms_property_ids" eval="[(6, 0, [])]" />
            <field
        name="template_id"
        ref="pms_notifications.pms_notification_template_reservation_prearrival_email"
      />

            <field name="rule_type">scheduled</field>
            <field name="target_model_id" ref="pms.model_pms_reservation" />

            <field name="time_field_name">checkin</field>
            <field name="offset_days">-3</field>
            <field name="offset_hours">0</field>
            <field name="time_window_minutes">60</field>
            <field name="scheduled_domain">[('state', '=', 'confirm')]</field>

            <field name="channel">email</field>
            <field name="send_immediately">True</field>
            <field name="max_sends_per_record">1</field>
        </record>

        <!-- Digital check-in reminder: 1 day before check-in -->
        <record
      id="pms_property_notification_rule_digital_checkin_reminder_email"
      model="pms.property.notification.rule"
    >
            <field name="name">Digital Check-in Reminder (Email)</field>
            <field name="active">True</field>
            <field name="pms_property_ids" eval="[(6, 0, [])]" />
            <field
        name="template_id"
        ref="pms_notifications.pms_notification_template_reservation_digital_checkin_reminder_email"
      />

            <field name="rule_type">scheduled</field>
            <field name="target_model_id" ref="pms.model_pms_reservation" />

            <field name="time_field_name">checkin</field>
            <field name="offset_days">-1</field>
            <field name="offset_hours">0</field>
            <field name="time_window_minutes">60</field>
            <field name="scheduled_domain">[('state', '=', 'confirm')]</field>

            <field name="channel">email</field>
            <field name="send_immediately">True</field>
            <field name="max_sends_per_record">1</field>
        </record>

        <!-- Checkout reminder: 1 day before checkout -->
        <record
      id="pms_property_notification_rule_checkout_reminder_email"
      model="pms.property.notification.rule"
    >
            <field name="name">Checkout Reminder (Email)</field>
            <field name="active">True</field>
            <field name="pms_property_ids" eval="[(6, 0, [])]" />
            <field
        name="template_id"
        ref="pms_notifications.pms_notification_template_reservation_checkout_reminder_email"
      />

            <field name="rule_type">scheduled</field>
            <field name="target_model_id" ref="pms.model_pms_reservation" />

            <field name="time_field_name">checkout</field>
            <field name="offset_days">-1</field>
            <field name="offset_hours">0</field>
            <field name="time_window_minutes">60</field>
            <field name="scheduled_domain">[('state', '=', 'confirm')]</field>

            <field name="channel">email</field>
            <field name="send_immediately">True</field>
            <field name="max_sends_per_record">1</field>
        </record>

        <!-- Thank you + review request: 1 day after checkout -->
        <record
      id="pms_property_notification_rule_thank_you_review_email"
      model="pms.property.notification.rule"
    >
            <field name="name">Thank You Review Request (Email)</field>
            <field name="active">True</field>
            <field name="pms_property_ids" eval="[(6, 0, [])]" />
            <field
        name="template_id"
        ref="pms_notifications.pms_notification_template_reservation_thank_you_review_email"
      />

            <field name="rule_type">scheduled</field>
            <field name="target_model_id" ref="pms.model_pms_reservation" />

            <field name="time_field_name">checkout</field>
            <field name="offset_days">1</field>
            <field name="offset_hours">0</field>
            <field name="time_window_minutes">60</field>
            <field name="scheduled_domain">[('state', '=', 'confirm')]</field>

            <field name="channel">email</field>
            <field name="send_immediately">True</field>
            <field name="max_sends_per_record">1</field>
        </record>

  </data>
</odoo>
