        <field name="model_id" ref="pms.model_pms_reservation" />
        <field
      name="subject"
    >Digital check-in reminder - {{ object.pms_property_id.name }}</field>
        <field
      name="email_from"
    >{{ (object.pms_property_id.email_formatted or user.email_formatted) if object.pms_property_id else user.email_formatted }}</field>
        <field name="email_to">{{ object.email or '' }}</field>
        <field name="lang">{{ object.lang or user.lang }}</field>
        <field name="auto_delete" eval="True" />
