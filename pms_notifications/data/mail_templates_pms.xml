        >
                    <tbody>
                        <tr>
                            <td
                style="padding: 2px 0; width: 170px; color: #666;"
              >Check-in</td>
                            <td style="padding: 2px 0;">
                                <t t-out="format_date(object.checkin)" />
                                <t t-if="property and property.checkin_time_info">
                                    &#160;(<t t-out="property.checkin_time_info" />)
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <td
                style="padding: 2px 0; width: 170px; color: #666;"
              >Check-out</td>
                            <td style="padding: 2px 0;">
                                <t t-out="format_date(object.checkout)" />
                                <t t-if="property and property.checkout_time_info">
                                    &#160;(<t t-out="property.checkout_time_info" />)
                                </t>
                            </td>
                        </tr>
                        <tr t-if="object.room_type_id">
                            <td
                style="padding: 2px 0; width: 170px; color: #666;"
              >Room type</td>
                            <td style="padding: 2px 0;">
                                <t
                  t-out="object.room_type_id.guest_display_name or object.room_type_id.name"
                />
                            </td>
                        </tr>
                    </tbody>
