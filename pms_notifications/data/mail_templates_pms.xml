                </p>

                <t t-if="property and property.critical_contact_phone">
                    <p style="margin: 12px 0 0 0;">
                        For urgent matters, you can reach us at:
                        <strong><t t-out="property.critical_contact_phone" /></strong>
                    </p>
                </t>

                <t t-if="property and property.default_email_signature">
                    <div style="margin-top: 18px;">
                        <t t-raw="property.default_email_signature" />
                    </div>
                </t>
            </div>
        </field>
    </record>


    <!-- =========================================================
        Mail Template record (mail.template) for pms.reservation
        Thank you + review request (1 day after checkout)
        ========================================================= -->

    <record id="mail_template_pms_reservation_thank_you_review" model="mail.template">
        <field name="name">PMS: Thank You Review Request</field>
        <field name="model_id" ref="pms.model_pms_reservation" />
        <field
      name="subject"
    >Thank you for staying with us - {{ object.pms_property_id.name }}</field>
        <field
      name="email_from"
    >{{ (object.pms_property_id.email_formatted or user.email_formatted) if object.pms_property_id else user.email_formatted }}</field>
        <field name="email_to">{{ object.email or '' }}</field>
        <field name="lang">{{ object.lang or user.lang }}</field>
        <field name="auto_delete" eval="True" />
        <field name="body_html" type="html">
            <div style="margin:0; padding:0;">
                <t t-set="property" t-value="object.pms_property_id" />
                <t t-set="customer" t-value="object.partner_id" />

                <p style="margin: 0 0 12px 0;">
                    <t t-if="customer and customer.name">
                        Hello <strong><t t-out="customer.name" /></strong>,
                    </t>
                    <t t-else="">Hello,</t>
                    <br />
                    Thank you for choosing <t
            t-out="property.name if property else ''"
          />. We hope you had a great stay.
                </p>

                <h3
          style="margin: 0 0 8px 0; padding: 0; font-size: 16px; font-weight: 600;"
        >Your stay</h3>

                <table
          style="width: 100%; border-collapse: collapse; margin: 0 0 16px 0;"
        >
                    <tbody>
                        <tr>
                            <td
                style="padding: 2px 0; width: 170px; color: #666;"
              >Check-in</td>
                            <td style="padding: 2px 0;"><t
                  t-out="format_date(object.checkin)"
                /></td>
                        </tr>
                        <tr>
                            <td
                style="padding: 2px 0; width: 170px; color: #666;"
              >Check-out</td>
                            <td style="padding: 2px 0;"><t
                  t-out="format_date(object.checkout)"
                /></td>
                        </tr>
                    </tbody>
                </table>

                <p style="margin: 0 0 10px 0;">
                    If you have a moment, we would really appreciate your feedback. Your review helps us improve and helps future guests choose with confidence.
                </p>

                <p style="margin: 0 0 10px 0;">
                    If anything was not perfect, please reply to this email so we can make it right.
                </p>

                <t t-if="property and property.critical_contact_phone">
                    <p style="margin: 12px 0 0 0;">
                        For urgent matters, you can reach us at:
                        <strong><t t-out="property.critical_contact_phone" /></strong>
                    </p>
                </t>

                <t t-if="property and property.default_email_signature">
                    <div style="margin-top: 18px;">
                        <t t-raw="property.default_email_signature" />
                    </div>
                </t>
            </div>
        </field>
    </record>


</odoo>
