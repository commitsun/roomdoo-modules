<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Inherit PMS Room Type form to add guest-facing description fields -->
    <record id="view_pms_room_type_form_notifications" model="ir.ui.view">
        <field name="name">pms.room.type.form.notifications</field>
        <field name="model">pms.room.type</field>
        <!-- TODO: adjust inherit_id to your real PMS room type form view ID -->
        <field name="inherit_id" ref="pms.pms_room_type_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Guest Communication">
                    <group>
                        <group>
                            <field name="guest_display_name" />
                            <field name="guest_short_description" />
                            <field name="guest_long_description" />
                        </group>
                        <group>
                            <field name="bed_configuration_text" />
                            <field name="view_description" />
                            <field name="amenities_summary" />
                        </group>
                    </group>
                    <group>
                        <field name="notification_internal_note" widget="text" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
