#. module: pms_satisfaction_survey
#: model:survey.survey,title:pms_satisfaction_survey.survey_pms_satisfaction_default
msgid "Stay Satisfaction Survey"
msgstr "Encuesta de satisfacción de la estancia"

#. module: pms_satisfaction_survey
#: model:survey.survey,description:pms_satisfaction_survey.survey_pms_satisfaction_default
msgid ""
"<p>Thank you for staying with us! Please take a minute to tell us about your "
"experience. Your feedback helps us improve.</p>"
msgstr ""
"<p>¡Gracias por alojarse con nosotros! Tómese un minuto para contarnos su "
"experiencia. Sus comentarios nos ayudan a mejorar.</p>"

#. module: pms_satisfaction_survey
#: model:survey.survey,description_done:pms_satisfaction_survey.survey_pms_satisfaction_default
msgid "<p>Thank you for your feedback. We hope to welcome you back soon!</p>"
msgstr ""
"<p>Gracias por sus comentarios. ¡Esperamos volver a verle pronto!</p>"

#. module: pms_satisfaction_survey
#: model:survey.question,title:pms_satisfaction_survey.survey_pms_satisfaction_q_overall
msgid "How would you rate your overall stay?"
msgstr "¿Cómo valoraría su estancia en general?"

#. module: pms_satisfaction_survey
#: model:survey.question,title:pms_satisfaction_survey.survey_pms_satisfaction_q_cleanliness
msgid "How would you rate the cleanliness of the room?"
msgstr "¿Cómo valoraría la limpieza de la habitación?"

#. module: pms_satisfaction_survey
#: model:survey.question,title:pms_satisfaction_survey.survey_pms_satisfaction_q_staff
msgid "How friendly and helpful was our staff?"
msgstr "¿Qué tal fue el trato y la amabilidad de nuestro personal?"

#. module: pms_satisfaction_survey
#: model:survey.question,title:pms_satisfaction_survey.survey_pms_satisfaction_q_nps
msgid ""
"How likely are you to recommend us to a friend or colleague? (0 = not at "
"all, 10 = extremely likely)"
msgstr ""
"¿Qué probabilidad hay de que nos recomiende a un amigo o compañero? (0 = "
"nada probable, 10 = totalmente probable)"

#. module: pms_satisfaction_survey
#: model:survey.question,title:pms_satisfaction_survey.survey_pms_satisfaction_q_comments
msgid "Any additional comments or suggestions?"
msgstr "¿Algún comentario o sugerencia adicional?"

#. module: pms_satisfaction_survey
#: model:survey.question,validation_error_msg:pms_satisfaction_survey.survey_pms_satisfaction_q_nps
msgid "Please enter a value between 0 and 10."
msgstr "Por favor, introduzca un valor entre 0 y 10."

