<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="pms_property_views_form" model="ir.ui.view">
        <field name="name">pms.property.inherit.view.form</field>
        <field name="model">pms.property</field>
        <field name="inherit_id" ref="pms.pms_property_views_form" />
        <field name="arch" type="xml">
            <field name="journal_normal_invoice_id" position="before">
                <field name="default_invoicing_policy" />
                <field
          name="margin_days_autoinvoice"
          attrs="{'invisible': [('default_invoicing_policy', '=', 'manual')]}"
        />
            </field>
            <field name="journal_normal_invoice_id" position="attributes">
                <attribute
          name="attrs"
        >{'required': [('default_invoicing_policy', '!=', 'manual')]}</attribute>
            </field>
            <field name="journal_simplified_invoice_id" position="attributes">
                <attribute
          name="attrs"
        >{'required': [('default_invoicing_policy', '!=', 'manual')]}</attribute>
            </field>
        </field>
    </record>
</odoo>
