<?xml version="1.0" ?>
<odoo>

        <record model="ir.ui.view" id="view_roomdoo_invoices_exporter">
                <field name="name">roomdoo_invoices.exporter</field>
                <field name="model">roomdoo.invoices.exporter</field>
                <field name="arch" type="xml">
                    <form string="Export Invoices">
                        <group>
                                <group>
                                        <field
                            name="date_start"
                            widget="daterange"
                            required="1"
                            options="{'related_end_date': 'date_end'}"
                        />
                                </group>
                                <group>
                                        <field
                            name="date_end"
                            widget="daterange"
                            required="1"
                            options="{'related_start_date': 'date_start'}"
                        />
                                </group>
                        </group>
                        <group>
                            <field name="company_id" options="{'no_create': True}" />
                            <field
                        name="property_ids"
                        widget="many2many_tags"
                        domain="[('company_id', '=', company_id)]"
                        options="{'no_create': True}"
                    />
                            <field
                        name="journal_ids"
                        widget="many2many_tags"
                        domain="[
                                    ('company_id', '=', company_id),
                                    ('type', 'in', ['sale', 'purchase']),
                                    '|',
                                    ('pms_property_ids', '=', False),
                                    ('pms_property_ids', 'in', property_ids)
                                ]"
                        options="{'no_create': True}"
                    />
                        </group>
                        <group>
                            <field name="export_journals" string="Pagos de facturas" />
                        </group>
                        <group>
                            <group
                        attrs="{'invisible': [('export_journals', '=', False)]}"
                    >
                                <field name="xls_journals_filename" invisible="1" />
                                <field
                            name="xls_journals_binary"
                            filename="xls_journals_filename"
                            readonly="1"
                            string="Pagos"
                        />
                            </group>
                        </group>
                        <footer>
                                <button
                        name="export"
                        string="Generar XLS"
                        type="object"
                        class="oe_highlight"
                    />
                                or
                                <button
                        string="Close"
                        class="oe_link"
                        special="cancel"
                    />
                        </footer>
                    </form>
                </field>
        </record>

        <record
        id="action_open_roomdoo_exporter_invoices"
        model="ir.actions.act_window"
    >
                <field name="name">Export Invoices</field>
                <field name="type">ir.actions.act_window</field>
                <field name="res_model">roomdoo.invoices.exporter</field>
                <field name="view_id" ref="view_roomdoo_invoices_exporter" />
                <field name="view_mode">form</field>
                <field name="target">new</field>
        </record>

</odoo>
