<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="lock_vendor_view_form" model="ir.ui.view">
        <field name="name">lock.vendor.form.omnitec</field>
        <field name="model">lock.vendor</field>
        <field name="inherit_id" ref="pms_smartlock_base.lock_vendor_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='notes']" position="before">
                <page
          name="omnitec_credentials"
          string="Omnitec Credentials"
          attrs="{'invisible': [('vendor_type', '!=', 'omnitec')]}"
        >
                    <group>
                        <field
              name="omnitec_osaccess"
              attrs="{'required': [('vendor_type', '=', 'omnitec')]}"
            />
                        <field
              name="omnitec_username"
              attrs="{'required': [('vendor_type', '=', 'omnitec')]}"
            />
                        <field
              name="omnitec_password"
              password="True"
              attrs="{'required': [('vendor_type', '=', 'omnitec')]}"
            />
                    </group>
                    <p class="text-muted">
                        Client ID and secret are Roomdoo app credentials, read
                        from the deployment environment per OsAccess version
                        (OMNITEC_CLIENT_ID / OMNITEC_CLIENT_SECRET, or
                        OMNITEC_LEGACY_CLIENT_ID / OMNITEC_LEGACY_CLIENT_SECRET).
                    </p>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
