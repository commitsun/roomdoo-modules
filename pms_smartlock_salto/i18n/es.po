#. module: pms_smartlock_salto
#: model_terms:ir.ui.view,arch_db:pms_smartlock_salto.lock_vendor_view_form
msgid ""
"Client ID and secret are Roomdoo app credentials, read\n"
"                        from the deployment environment (SALTO_CLIENT_ID /\n"
"                        SALTO_CLIENT_SECRET). Fetch the roles, then assign the\n"
"                        basic <b>User</b> role (only opens doors) — never an\n"
"                        admin role."
msgstr ""
"El Client ID y el secret son credenciales de la app de Roomdoo, leídas\n"
"                        del entorno de despliegue (SALTO_CLIENT_ID /\n"
"                        SALTO_CLIENT_SECRET). Trae los roles y luego asigna el\n"
"                        rol básico <b>User</b> (solo abre puertas) — nunca un\n"
"                        rol de administrador."

